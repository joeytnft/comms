# Guardian Comm — Mobile App Environment Variables
# Copy this to .env and fill in your values

# API Server (EXPO_PUBLIC_ prefix required for Expo to expose these to the app)
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SOCKET_URL=ws://localhost:3001

# LiveKit (Voice/PTT)
EXPO_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# Push Notifications (Firebase)
# Get these from Firebase Console
# FIREBASE_API_KEY=
# FIREBASE_PROJECT_ID=
# FIREBASE_MESSAGING_SENDER_ID=
