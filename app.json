{
  "expo": {
    "name": "Guardian Comm",
    "slug": "guardian-comm",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "guardiancomm",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.guardiancomm.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Guardian Comm needs your location to share with your security team.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Guardian Comm needs background location to keep your team informed of your position.",
        "NSMicrophoneUsageDescription": "Guardian Comm needs microphone access for push-to-talk communication.",
        "NSCameraUsageDescription": "Guardian Comm needs camera access for incident reports.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "location",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.guardiancomm.app",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "VIBRATE",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-camera",
      "expo-notifications",
      "expo-secure-store",
      "expo-av",
      "expo-asset",
      "expo-audio",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow Guardian Comm to connect to Bluetooth PTT accessories."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0305c4ae-e29a-4d01-afbf-402f427c8e54"
      }
    },
    "owner": "joeyt56"
  }
}