{
  "expo": {
    "name": "GatherSafe",
    "slug": "guardian-comm",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "gathersafe",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "https://u.expo.dev/0305c4ae-e29a-4d01-afbf-402f427c8e54"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gathersafe2.www",
      "googleServicesFile": "./GoogleService-Info.plist",
      "entitlements": {
        "com.apple.developer.usernotifications.critical-alerts": true
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GatherSafe needs your location to share with your security team.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GatherSafe needs background location to keep your team informed of your position.",
        "NSMicrophoneUsageDescription": "GatherSafe needs microphone access for push-to-talk communication.",
        "NSCameraUsageDescription": "GatherSafe needs camera access for incident reports.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "push-to-talk",
          "location",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "GatherSafe uses Face ID to unlock the app quickly and securely."
      },
      "buildNumber": "83"
    },
    "android": {
      "package": "com.gathersafe2.www",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_PHONE_NUMBERS",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_NOTIFICATION_POLICY"
      ],
      "versionCode": 6
    },
    "plugins": [
      [
        "./plugins/withDevelopmentTeam",
        {
          "developmentTeam": "VXK7V8D63S"
        }
      ],
      "./plugins/withPushToTalk",
      "./plugins/withLiveActivity",
      "./plugins/withPodfileFixes",
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "expo-secure-store",
      "expo-av",
      "expo-asset",
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          },
          "ios": {
            "deploymentTarget": "15.1",
            "bitcode": false
          }
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow GatherSafe to connect to Bluetooth PTT accessories."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0305c4ae-e29a-4d01-afbf-402f427c8e54"
      }
    },
    "owner": "joeyt56"
  }
}
