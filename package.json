    "@react-navigation/native-stack": "^6.9.0",
    "axios": "^1.7.0",
    "date-fns": "^3.6.0",
    "expo": "~52.0.0",
    "expo-asset": "~10.0.0",
    "expo-av": "~14.0.0",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.0",
