# Guardian Comm Server — Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://guardian:password@localhost:5432/guardian_comm

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-secure-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# LiveKit (Voice/PTT SFU)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=http://localhost:7880

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# RevenueCat (subscription billing)
# REVENUECAT_API_KEY=your-revenuecat-api-key
# REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# File Storage (S3-compatible)
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=guardian-comm
