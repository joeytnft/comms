// GatherSafe — Database Schema
// Run: npx prisma migrate dev --name init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ORGANIZATIONS
// ============================================================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique @default(cuid())
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Subscription
  subscriptionTier     SubscriptionTier   @default(FREE)
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  rcCustomerId         String?            @unique // RevenueCat customer ID

  pcoIntegrationEnabled Boolean @default(false)

  users              User[]
  groups             Group[]
  alerts             Alert[]
  incidents          Incident[]
  billingEvents      BillingEvent[]
  geofences          Geofence[]
  serviceSchedules   ServiceSchedule[]
  serviceTemplates   ServiceTemplate[]
  posts              Post[]
  campuses           Campus[]
  responsePlans      ResponsePlan[]
  pcoConnection      PcoConnection?
  trainingEvents     TrainingEvent[]
  qualificationTypes QualificationType[]

  @@map("organizations")
}

// ============================================================================
// CAMPUSES (Enterprise multi-campus)
// ============================================================================

model Campus {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  address        String?
  inviteCode     String   @unique @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id])
  users         User[]
  campusMemberships CampusUser[]
  groups        Group[]
  alerts        Alert[]
  incidents     Incident[]
  geofence      Geofence?

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("campuses")
}

model CampusUser {
  id        String   @id @default(cuid())
  campusId  String
  userId    String
  joinedAt  DateTime @default(now())

  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campusId, userId])
  @@index([campusId])
  @@index([userId])
  @@map("campus_users")
}

enum SubscriptionTier {
  FREE
  STARTER
  TEAM
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model BillingEvent {
  id             String            @id @default(cuid())
  organizationId String
  type           String            // e.g. 'subscription_created', 'payment_succeeded', 'tier_changed'
  tier           SubscriptionTier?
  rcEventId      String?           @unique // Idempotency key from RevenueCat
  metadata       Json?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@map("billing_events")
}

// ============================================================================
// USERS
// ============================================================================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  displayName     String
  phone           String?
  avatarUrl       String?
  publicKey       String?  // E2E encryption public key
  expoPushToken   String?  // Expo push notification token
  organizationId  String
  campusId        String?
  lastSeenAt      DateTime?
  pushToken       String?  // Expo push notification token
  isOrgAdmin      Boolean  @default(false)
  accountStatus   String   @default("ACTIVE") // ACTIVE | INVITED
  pcoPersonId     String?
  inviteToken     String?  @unique
  inviteExpiresAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id])
  campus            Campus?           @relation(fields: [campusId], references: [id])
  campusMemberships CampusUser[]
  memberships       GroupMembership[]
  sentMessages    Message[]         @relation("sender")
  triggeredAlerts Alert[]           @relation("triggeredBy")
  reportedIncidents Incident[]      @relation("reportedBy")
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  location             UserLocation?
  pttLogs         PttLog[]
  pttPushTokens   PttPushToken[]
  shiftAssignments     ShiftAssignment[]  @relation("shiftAssignments")
  swapRequestsReceived ShiftSwapRequest[] @relation("swapRequestsReceived")
  createdServices      ServiceSchedule[]  @relation("serviceCreatedBy")
  createdTemplates     ServiceTemplate[]  @relation("templateCreatedBy")
  availability         ServiceAvailability[]
  memberQualifications MemberQualification[]
  trainingSignups      TrainingSignup[]
  createdTrainings     TrainingEvent[]    @relation("trainingCreator")

  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
// LOCATION
// ============================================================================

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  latitude  Float
  longitude Float
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_locations")
}

// ============================================================================
// GROUPS & MEMBERSHIPS
// ============================================================================

model Group {
  id              String    @id @default(cuid())
  name            String
  description     String?
  type            GroupType
  organizationId  String
  campusId        String?
  parentGroupId   String?   // Points to lead group (for sub-groups)
  iconColor       String?
  inviteCode      String?   @unique  // Shareable code for self-join
  groupKey        String?   // Shared AES-256 key (hex) for message encryption
  alertsEnabled   Boolean   @default(true)  // Whether members can send/receive alerts
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization      @relation(fields: [organizationId], references: [id])
  campus          Campus?           @relation(fields: [campusId], references: [id])
  parentGroup     Group?            @relation("GroupHierarchy", fields: [parentGroupId], references: [id])
  subGroups       Group[]           @relation("GroupHierarchy")
  memberships     GroupMembership[]
  messages        Message[]
  pttLogs         PttLog[]
  pttPushTokens   PttPushToken[]
  alertTargets    AlertGroupTarget[]
  trainingTargets TrainingGroupTarget[]

  @@map("groups")
}

enum GroupType {
  LEAD
  SUB
}

model GroupMembership {
  id       String     @id @default(cuid())
  groupId  String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_memberships")
}

enum MemberRole {
  ADMIN
  MEMBER
}

// ============================================================================
// MESSAGES
// ============================================================================

model Message {
  id               String      @id @default(cuid())
  groupId          String
  senderId         String?
  type             MessageType @default(TEXT)
  encryptedContent String      // E2E encrypted — server cannot read
  iv               String      // Initialization vector
  createdAt        DateTime    @default(now())

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User? @relation("sender", fields: [senderId], references: [id], onDelete: SetNull)
  readReceipts ReadReceipt[]

  @@index([groupId, createdAt])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  ALERT
  SYSTEM
}

model ReadReceipt {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("read_receipts")
}

// ============================================================================
// ALERTS
// ============================================================================

model Alert {
  id              String     @id @default(cuid())
  organizationId  String
  campusId        String?
  triggeredById   String?
  level           AlertLevel
  alertType       String?    // e.g. MEDICAL, SUSPICIOUS_PERSON, LOCKDOWN, etc.
  message         String?
  latitude        Float?
  longitude       Float?
  priorityTone    Boolean    @default(false)
  photoUrl        String?
  resolvedAt      DateTime?
  resolvedById    String?
  createdAt       DateTime   @default(now())

  organization    Organization          @relation(fields: [organizationId], references: [id])
  campus          Campus?               @relation(fields: [campusId], references: [id])
  triggeredBy     User?                 @relation("triggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  acknowledgments AlertAcknowledgment[]
  targetGroups    AlertGroupTarget[]    // Empty = global (all groups in org)

  @@index([organizationId, createdAt])
  @@map("alerts")
}

model AlertGroupTarget {
  id      String @id @default(cuid())
  alertId String
  groupId String

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([alertId, groupId])
  @@map("alert_group_targets")
}

enum AlertLevel {
  ATTENTION
  WARNING
  EMERGENCY
}

model AlertAcknowledgment {
  id             String   @id @default(cuid())
  alertId        String
  userId         String
  acknowledgedAt DateTime @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, userId])
  @@map("alert_acknowledgments")
}

// ============================================================================
// INCIDENTS
// ============================================================================

model Incident {
  id               String          @id @default(cuid())
  organizationId   String
  campusId         String?
  reportedById     String?
  title            String
  encryptedDetails String          // E2E encrypted
  severity         IncidentSeverity
  status           IncidentStatus  @default(OPEN)
  latitude         Float?
  longitude        Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  resolvedAt       DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id])
  campus       Campus?         @relation(fields: [campusId], references: [id])
  reportedBy   User?           @relation("reportedBy", fields: [reportedById], references: [id], onDelete: SetNull)
  photos       IncidentPhoto[]

  @@index([organizationId, createdAt])
  @@map("incidents")
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model IncidentPhoto {
  id           String   @id @default(cuid())
  incidentId   String
  encryptedUrl String   // Encrypted S3 URL
  createdAt    DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("incident_photos")
}

// ============================================================================
// PTT VOICE LOGS
// ============================================================================

model PttLog {
  id         String   @id @default(cuid())
  groupId    String
  senderId   String
  audioUrl   String?
  durationMs Int      @default(0)
  createdAt  DateTime @default(now())

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@map("ptt_logs")
}

// Ephemeral APNs device tokens for Apple's Push To Talk framework.
// Each token is valid only while the user is joined to that PTT channel.
// Tokens are replaced on every new channel join.
model PttPushToken {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  token     String   // Hex-encoded ephemeral APNs device token
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@map("ptt_push_tokens")
}

// ============================================================================
// SCHEDULE / SHIFT MANAGEMENT
// ============================================================================

model Post {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  zone           String?
  description    String?
  createdAt      DateTime @default(now())

  organization   Organization       @relation(fields: [organizationId], references: [id])
  assignments    ShiftAssignment[]
  templateSlots  TemplateRoleSlot[]

  @@unique([organizationId, name])
  @@map("posts")
}

model ServiceTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  dayOfWeek      Int      // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
  startTime      String   // "09:00" 24h
  description    String?
  isActive       Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  createdBy    User?              @relation("templateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  roleSlots    TemplateRoleSlot[]
  services     ServiceSchedule[]

  @@index([organizationId])
  @@map("service_templates")
}

model TemplateRoleSlot {
  id         String  @id @default(cuid())
  templateId String
  postId     String?
  roleName   String
  count      Int     @default(1)

  template ServiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  post     Post?           @relation(fields: [postId], references: [id])

  @@map("template_role_slots")
}

model ServiceSchedule {
  id             String   @id @default(cuid())
  organizationId String
  templateId     String?  // null = one-off special service
  name           String
  serviceDate    DateTime
  description    String?
  createdById    String?
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id])
  template     ServiceTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("serviceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignments  ShiftAssignment[]
  availability ServiceAvailability[]

  @@index([organizationId, serviceDate])
  @@map("service_schedules")
}

model ShiftAssignment {
  id        String           @id @default(cuid())
  serviceId String
  userId    String
  postId    String?
  role      String?
  notes     String?
  status    AssignmentStatus @default(PENDING)
  createdAt DateTime         @default(now())

  service      ServiceSchedule    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user         User               @relation("shiftAssignments", fields: [userId], references: [id], onDelete: Cascade)
  post         Post?              @relation(fields: [postId], references: [id])
  checkIn      CheckIn?
  swapRequests ShiftSwapRequest[] @relation("fromAssignment")

  @@unique([serviceId, userId])
  @@map("shift_assignments")
}

model ServiceAvailability {
  id        String   @id @default(cuid())
  serviceId String
  userId    String
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service ServiceSchedule @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serviceId, userId])
  @@map("service_availability")
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model CheckIn {
  id           String    @id @default(cuid())
  assignmentId String    @unique
  checkedInAt  DateTime  @default(now())
  checkedOutAt DateTime?

  assignment ShiftAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("check_ins")
}

model ShiftSwapRequest {
  id               String     @id @default(cuid())
  fromAssignmentId String
  toUserId         String
  message          String?
  status           SwapStatus @default(PENDING)
  respondedAt      DateTime?
  createdAt        DateTime   @default(now())

  fromAssignment ShiftAssignment @relation("fromAssignment", fields: [fromAssignmentId], references: [id], onDelete: Cascade)
  toUser         User            @relation("swapRequestsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@map("shift_swap_requests")
}

enum SwapStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ============================================================================
// INCIDENT RESPONSE PLANS
// ============================================================================

model ResponsePlan {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  steps        ResponsePlanStep[]

  @@index([organizationId])
  @@map("response_plans")
}

model ResponsePlanStep {
  id          String  @id @default(cuid())
  planId      String
  order       Int
  action      String  // Description of the action
  assignedTo  String? // Role or position name (free text)

  plan ResponsePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("response_plan_steps")
}

// ============================================================================
// GEOFENCING
// ============================================================================

// ============================================================================
// PLANNING CENTER INTEGRATION
// ============================================================================

model PcoConnection {
  id             String   @id @default(cuid())
  organizationId String   @unique
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  scope          String   @default("people services")
  pcoOrgId       String?
  pcoOrgName     String?
  connectedById  String
  connectedAt    DateTime @default(now())
  lastSyncAt     DateTime?

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  people          PcoPerson[]
  plans           PcoPlan[]
  teams           PcoTeam[]
  teamMembers     PcoTeamMember[]
  scheduledPeople PcoScheduledPerson[]

  @@map("pco_connections")
}

model PcoPerson {
  id             String   @id @default(cuid())
  organizationId String
  pcoId          String   // PCO's person ID
  name           String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  avatarUrl      String?
  status         String   @default("active")
  syncedAt       DateTime @default(now()) @updatedAt

  connection PcoConnection @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)

  @@unique([organizationId, pcoId])
  @@index([organizationId])
  @@map("pco_people")
}

model PcoPlan {
  id              String   @id @default(cuid())
  organizationId  String
  pcoId           String
  serviceTypeId   String
  serviceTypeName String
  title           String?
  seriesTitle     String?
  sortDate        DateTime?
  totalLength     Int      @default(0) // seconds
  syncedAt        DateTime @default(now()) @updatedAt

  connection PcoConnection @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)

  @@unique([organizationId, pcoId])
  @@index([organizationId, sortDate])
  @@map("pco_plans")
}

model PcoTeam {
  id              String   @id @default(cuid())
  organizationId  String
  pcoId           String
  serviceTypeId   String
  serviceTypeName String
  name            String
  groupId         String?  // linked GatherSafe group
  syncedAt        DateTime @default(now()) @updatedAt

  connection PcoConnection @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)

  @@unique([organizationId, pcoId])
  @@index([organizationId])
  @@map("pco_teams")
}

model PcoTeamMember {
  id             String   @id @default(cuid())
  organizationId String
  pcoTeamId      String
  pcoPersonId    String
  syncedAt       DateTime @default(now()) @updatedAt

  connection PcoConnection @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)

  @@unique([organizationId, pcoTeamId, pcoPersonId])
  @@index([organizationId, pcoTeamId])
  @@map("pco_team_members")
}

model PcoScheduledPerson {
  id             String   @id @default(cuid())
  organizationId String
  pcoPlanId      String
  pcoPersonId    String
  pcoTeamId      String?
  status         String   @default("U") // C=Confirmed D=Declined U=Unconfirmed
  position       String?
  syncedAt       DateTime @default(now()) @updatedAt

  connection PcoConnection @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)

  @@unique([organizationId, pcoPlanId, pcoPersonId])
  @@index([organizationId, pcoPlanId])
  @@map("pco_scheduled_people")
}

model Geofence {
  id             String   @id @default(cuid())
  organizationId String
  campusId       String   @unique
  name           String
  latitude       Float
  longitude      Float
  radius         Float    // metres
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  campus       Campus       @relation(fields: [campusId], references: [id])

  @@index([organizationId])
  @@map("geofences")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ============================================================================
// QUALIFICATIONS
// ============================================================================

model QualificationType {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  validityDays   Int      @default(0) // 0 = never expires
  isActive       Boolean  @default(true)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberQualifications MemberQualification[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("qualification_types")
}

model MemberQualification {
  id                  String    @id @default(cuid())
  userId              String
  qualificationTypeId String
  earnedDate          DateTime
  expiresAt           DateTime?
  notes               String?
  awardedBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualificationType QualificationType @relation(fields: [qualificationTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, qualificationTypeId])
  @@index([userId])
  @@index([qualificationTypeId])
  @@map("member_qualifications")
}

// ============================================================================
// TRAINING EVENTS
// ============================================================================

enum SignupStatus {
  CONFIRMED
  CANCELLED
  WAITLISTED
}

model TrainingEvent {
  id             String    @id @default(cuid())
  organizationId String
  title          String
  description    String?
  location       String?
  startDate      DateTime
  endDate        DateTime?
  maxAttendees   Int?
  isActive       Boolean   @default(true)
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?                 @relation("trainingCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  groupTargets TrainingGroupTarget[]
  signups      TrainingSignup[]

  @@index([organizationId])
  @@index([startDate])
  @@map("training_events")
}

model TrainingGroupTarget {
  id              String @id @default(cuid())
  trainingEventId String
  groupId         String

  trainingEvent TrainingEvent @relation(fields: [trainingEventId], references: [id], onDelete: Cascade)
  group         Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([trainingEventId, groupId])
  @@index([trainingEventId])
  @@index([groupId])
  @@map("training_group_targets")
}

model TrainingSignup {
  id              String       @id @default(cuid())
  trainingEventId String
  userId          String
  status          SignupStatus @default(CONFIRMED)
  notes           String?
  signedUpAt      DateTime     @default(now())

  trainingEvent TrainingEvent @relation(fields: [trainingEventId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trainingEventId, userId])
  @@index([trainingEventId])
  @@index([userId])
  @@map("training_signups")
}
